# Server
PORT=3000

# MongoDB — use Atlas free tier connection string
# Go to mongodb.com/atlas → create free cluster → get connection string
MONGO_URI=mongodb+srv://youruser:yourpass@cluster0.xxxxx.mongodb.net/sutech_emails?retryWrites=true&w=majority

# ──────────────────────────────────────────────
# SMTP — OPTION A: Gmail (use this NOW for free)
# ──────────────────────────────────────────────
# 1. Go to myaccount.google.com → Security → 2-Step Verification → ON
# 2. Then go to App Passwords → generate one for "Mail"
# 3. Use that 16-character password below
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your.gmail@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx

# ──────────────────────────────────────────────
# SMTP — OPTION B: University email (swap later)
# ──────────────────────────────────────────────
# SMTP_HOST=smtp.sut.edu.eg
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=ieee@sut.edu.eg
# SMTP_PASS=university_password_here

SMTP_FROM_NAME=IEEE SUTech Student Branch
SMTP_FROM_EMAIL=ieee@sut.edu.eg

# Admin password to protect endpoints
ADMIN_API_KEY=change_this_to_something_secret

# Delay between each email (milliseconds) — prevents spam flagging
EMAIL_DELAY_MS=3000