# ══════════════════════════════════════════════════════════════
# EMAIL — Power Automate (الطريقة الأسهل لـ Office 365)
# ══════════════════════════════════════════════════════════════
# 1. make.powerautomate.com → Create → Instant cloud flow
# 2. Trigger: "When an HTTP request is received"
# 3. Sample payload: { "to": "x@y.com", "subject": "Test", "html": "<h1>Hi</h1>" }
# 4. New step: Office 365 Outlook → Send an email (V2)
#    - To: Dynamic content → to
#    - Subject: Dynamic content → subject
#    - Body: Dynamic content → html  (فعّل Is HTML = Yes)
# 5. Save → انسخ الـ HTTP POST URL من الـ trigger
POWER_AUTOMATE_WEBHOOK_URL=https://default4cf493e2c44f4a859650f432e907ba.34.environment.api.powerplatform.com:443/powerautomate/automations/direct/workflows/7a00667b01884dc39f6f7c77b71dc320/triggers/manual/paths/invoke?api-version=1&sp=%2Ftriggers%2Fmanual%2Frun&sv=1.0&sig=aZsaUBCW_lqDu0ezCGqJbFoJFCoMvxz7TevS8O0ATDA

# ══════════════════════════════════════════════════════════════
# خطوات الإعداد (مرة واحدة فقط):
# 1. portal.azure.com → Azure Active Directory → App registrations → New registration
#    - Name: "SUTech Email Automation"
#    - Supported account types: Accounts in this organizational directory only
#    - Click Register
# 2. انسخ: Application (client) ID  →  AZURE_CLIENT_ID
#           Directory (tenant) ID   →  AZURE_TENANT_ID
# 3. Certificates & secrets → New client secret → انسخ القيمة VALUE → AZURE_CLIENT_SECRET
# 4. API permissions → Add a permission → Microsoft Graph → Application permissions
#    → ابحث عن Mail.Send → Add permissions → Grant admin consent
# 5. الإيميل الراسل → AZURE_SENDER_EMAIL
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_SENDER_EMAIL=IEEE.SUTech@sut.edu.eg

