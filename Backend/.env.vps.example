# Core
PORT=3000
NODE_ENV=production
BASE_URL=https://your-domain.com
CORS_ORIGIN=https://your-domain.com

# Database
# Option A: Atlas
# MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/ieee_sutech_platform?retryWrites=true&w=majority

# Option B: Local mongo service from docker-compose
MONGO_URI=mongodb://mongo:27017/ieee_sutech_platform

# Auth (required)
JWT_ACCESS_SECRET=replace_with_long_random_secret_access
JWT_REFRESH_SECRET=replace_with_long_random_secret_refresh
JWT_ACCESS_EXPIRES=2h
JWT_REFRESH_EXPIRES=7d

# Initial admin account
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=change_me_now

# Optional email setup
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM_NAME=IEEE SUTECH
SMTP_FROM_EMAIL=your_email@gmail.com
ADMIN_API_KEY=replace_with_secret_api_key

# Optional judge tuning
JUDGE_CONCURRENCY=3
JUDGE_COMPARE_MODE=token
JUDGE_COMPILE_TIMEOUT_MS=20000
JUDGE_MAX_OUTPUT_CHARS=200000
JUDGE_MAX_STDERR_CHARS=10000
JUDGE_MAX_CODE_CHARS=200000
